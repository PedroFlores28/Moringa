      background-size contain !important
      background-repeat no-repeat !important
      z-index 2 !important
      opacity 0.9 !important
      
    >section
      position absolute !important
      bottom 0 !important
      left 0 !important
      width 100% !important
      height 70vh !important
      background white !important
      backdrop-filter none !important
      z-index 2 !important
      overflow hidden !important
      border-radius 50px 50px 0 0 !important
      
  // Estilos específicos para la página de registro en móvil
  @media (max-width: 768px)
    &.register-page
      &::before
        height 20vh !important
        
      &::after
        top 5% !important
        left 30% !important
        width 60px !important
        height 60px !important
        
      >section
        height 85vh !important
        top 15vh !important
        border-radius 40px 40px 0 0 !important
        // En registro móvil dejamos más aire debajo de las pestañas
        // para que el primer campo no quede pegado a la barra superior.
        padding-top 32px !important

        // Evitar que el formulario se suba por el margin-top negativo global
        // y por eso quede recortado detrás de la barra de tabs.
        .content
          .form
            margin-top 0 !important
            justify-content flex-start !important

      // Refuerzo extra: asegurar que el margin-top negativo global no
      // recorte el primer campo (DNI) en móvil.
      .content
        .form
          margin-top 0 !important
          justify-content flex-start !important
        
      // Alinear anchos en móvil: filas dobles y campos simples
      // deben encajar dentro del mismo bloque visual.
      @media (max-width: 480px)
        .form-field
          .input-container
            width 95% !important
            max-width 350px !important
            margin 0 auto !important

        .form-row
          .form-field
            .input-container
              width 100% !important
              max-width 100% !important

        .input-container
          .input-register-new
            width 100% !important
            max-width 100% !important

      @media (max-width: 375px)
        .form-field
          .input-container
            max-width 320px !important

  // Login móvil: Frame 2 a pantalla completa, formulario sobre zona crema (sin tarjeta blanca)
  @media (max-width: 768px)
    &.login-page
      background #ffffff !important

      &::before
        position fixed !important
        top 0 !important
        left 0 !important
        right 0 !important
        width 100% !important
        height 100% !important
        background #ffffff url('assets/img/logo/Frame 2.svg') no-repeat center top / cover !important
        z-index 0 !important

      &::after
        display none !important

      > #content-auth
        position relative !important
        top auto !important
        bottom auto !important
        left 0 !important
        width 100% !important
        height 100vh !important
        background transparent !important
        backdrop-filter none !important
        border-radius 0 !important
        overflow visible !important
        z-index 2 !important

        .content
          height 100%
          width 100%

        .form
          background transparent !important
          backdrop-filter none !important
          border-radius 0 !important
          min-height 100vh !important
          max-height 100vh !important
          height 100vh !important
          margin-top 0 !important
          padding 44vh 16px 28px !important
          justify-content flex-start !important
          overflow-y auto !important
          -webkit-overflow-scrolling touch

      .login-panel
        max-width 100%
        width 100%
        padding 0 20px 20px
        margin-top -6px

      .login-form-leaf
        display flex
        justify-content center
        align-items flex-end
        gap 4px
        margin 0 0 8px
        color auth-gold
        font-size 13px
        line-height 1

        i:nth-child(1)
          transform rotate(-28deg) translateY(4px)
          font-size 11px
          opacity 0.85

        i:nth-child(2)
          font-size 15px

        i:nth-child(3)
          transform rotate(28deg) translateY(4px)
          font-size 11px
          opacity 0.85

      .login-form-header
        position static
        margin-bottom 12px
        padding-top 0

      .login-mobile-hero
        position fixed
        top 0
        left 0
        right 0
        height 42vh
        max-height 400px
        display flex
        flex-direction column
        align-items center
        justify-content flex-start
        z-index 3
        pointer-events none
        box-sizing border-box
        padding-top calc(80px + env(safe-area-inset-top, 0px))
        padding-left 16px
        padding-right 16px

      .login-mobile-hero .login-form-logo-wrap
        width 162px
        height (162px * 401 / 512)
        margin 0 auto 6px
        transform translateX(2px)

      .login-mobile-hero .login-form-logo
        width 162px
        margin-top (-162px * 55 / 512)

      .login-mobile-hero .login-form-brand
        display block !important
        margin 0
        font-size 11px
        font-weight 700
        letter-spacing 0.00em
        color auth-gold
        line-height 1.15
        text-align center

      .login-mobile-hero .login-form-brand-sub
        display block !important
        margin 2px 0 0
        font-size 11px
        font-weight 700
        letter-spacing 0.02em
        color auth-gold
        line-height 1
        text-align center

      .login-form-title
        font-size 20px
        font-weight 700
        line-height 1.25

      .login-field
        width 100%
        max-width 268px
        margin-left auto
        margin-right auto
        margin-bottom 4px

      .login-label
        margin-left 4px
        font-size 14px

      .login-input-wrap,
      .login-button
        width 100%
        max-width 268px
        margin-left auto
        margin-right auto

      .login-input
        height 46px !important
        font-size 14px !important
        margin-bottom 16px !important
        border 2px solid auth-green !important
        border-radius 12px !important
        background #f3f3f3 !important

      .login-button
        height 46px
        font-size 16px
        margin-top 4px
        border-radius 12px !important
        background linear-gradient(90deg, #b8893a 0%, auth-gold 45%, auth-gold-light 100%) !important
        box-shadow 0 4px 14px rgba(201, 162, 77, 0.35)

      .login-forgot
        margin-top 16px

        a
          font-size 14px

      .login-footer
        display block !important
        margin-top 20px
        text-align center

        .login-link
          margin-top 0 !important

          small
            font-size 14px
            color #888

            a
              color auth-gold
              font-weight 500
              text-decoration underline

      @media (max-width: 480px)
        .login-field,
        .login-input-wrap,
        .login-button
          max-width 252px

  .welcome-title-form
    text-align center
    margin 25px 0 60px 0
    
    h1
      font-size 32px
      font-weight 900
      color #111111
      background linear-gradient(90deg, #111111 33%, #111111 25%, #e91e63 70%)
      -webkit-background-clip text
      background-clip text
      -webkit-text-fill-color transparent
      margin 0
      font-family 'Open Sans', sans-serif
      
    // Responsive
    @media (max-width: 768px)
      margin 10px 0 15px 0
      
      h1
        font-size 20px
        
    @media (max-width: 480px)
      margin 8px 0 12px 0
      
      h1
        font-size 18px
        
    @media (max-width: 375px)
      margin 6px 0 10px 0
      
      h1
        font-size 16px

  .register-title-form
    text-align center
    margin 25px 0 30px 0
    
    h1
      font-size 32px
      font-weight 900
      color auth-green
      margin 0
      font-family 'Open Sans', sans-serif
      
    // Responsive
    @media (max-width: 768px)
      display none !important
        
    @media (max-width: 480px)
      display none !important

  // Estilos para el nuevo formulario de registro
  .form-field
    position relative
    margin-bottom 15px
    
    // Responsive
    @media (max-width: 768px)
      margin-bottom 10px
      
    @media (max-width: 480px)
      margin-bottom 8px
      
    @media (max-width: 375px)
      margin-bottom 6px
    
  .form-row
    display flex
    gap 15px
    justify-content center
    width 80%
    max-width 509px
    margin 0 auto
    
    &:first-of-type
      margin-top -10px
    
    .form-field
      flex 1
      max-width 250px
      
      
    .input-register-new
      width 100%
      max-width 250px
      
    // Responsive
    @media (max-width: 768px)
      width 90%
      max-width 400px
      gap 10px
      align-items stretch
      
      .form-field
        flex 1 1 0
        min-width 0
        max-width none
        
      .input-register-new
        width 100%
        max-width 100%
        border-radius 10px !important
        
    @media (max-width: 480px)
      flex-direction row
      gap 8px
      width 95%
      max-width 350px
      align-items stretch
      
      .form-field
        flex 1 1 0
        min-width 0
        max-width none
        
      .input-register-new
        width 100%
        max-width 100%
        border-radius 10px !important
        font-size 14px
        padding 8px 10px
        height 42px
        
    @media (max-width: 375px)
      gap 6px
      width 95%
      max-width 300px
      align-items stretch
      
      .form-field
        flex 1 1 0
        min-width 0
        max-width none
        
      .input-register-new
        width 100%
        max-width 100%
        border-radius 10px !important
        font-size 13px
        padding 7px 9px
        height 40px
      
  .input-register-new
    width 80%
    max-width 509px
    padding 10px 16px
    height 45px
    border 2px solid auth-green
    border-radius 10px
    font-size 14px
    font-family 'Open Sans', sans-serif
    background #f3f3f3
    color #333
    transition all 0.3s ease
    
    &:focus
      outline none
      border-color auth-green
      box-shadow 0 0 0 3px rgba(19, 64, 44, 0.12)
      
    // Responsive
    @media (max-width: 768px)
      width 90%
      max-width 400px
      font-size 15px
      padding 8px 10px
      margin-bottom 12px
      border-radius 10px !important
      height 42px
      
    @media (max-width: 480px)
      width 95%
      max-width 350px
      padding 8px 10px
      margin-bottom 8px
      font-size 14px
      border-radius 10px !important
      height 42px
      
    @media (max-width: 375px)
      width 95%
      max-width 320px
      padding 7px 9px
      margin-bottom 8px
      font-size 13px
      border-radius 10px !important
      height 40px
      
    &::placeholder
      color #999
      
    &.error
      border-color #e74c3c

      
  .select-field
    appearance none
    background-image url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2313402c' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6,9 12,15 18,9'%3e%3c/polyline%3e%3c/svg%3e")
    background-repeat no-repeat
    background-position right 12px center
    background-size 16px
    padding-right 40px
    
    
  .checkbox-field
    margin-top -16px
    display flex
    justify-content flex-start
    width 80%
    max-width 509px
    margin-left auto
    margin-right auto
    
    // Responsive
    @media (max-width: 768px)
      width 90%
      max-width 400px
      
    @media (max-width: 480px)
      width 95%
      max-width 350px
    
  .terms-field

    display flex
    justify-content center
    width 80%
    max-width 509px
    margin-left auto
    margin-right auto
    
    // Responsive
    @media (max-width: 768px)
      width 90%
      max-width 400px
      
    @media (max-width: 480px)
      width 95%
      max-width 350px
    
  .checkbox-label
    display flex
    align-items center
    gap 8px
    cursor pointer
    
  .checkbox-input
    width 16px
    height 16px
    border 2px solid auth-green
    border-radius 0
    background white
    cursor pointer
    
  .checkbox-text
    color #666
    font-size 14px
    font-family 'Open Sans', sans-serif
    
  .register-button
    width 80%
    max-width 509px
    height 50px
    padding 15px
    background linear-gradient(90deg, #b8893a 0%, auth-gold 45%, auth-gold-light 100%)
    color white
    border none
    border-radius 0
    font-size 16px
    font-weight bold
    font-family 'Open Sans', sans-serif
    cursor pointer
    transition all 0.3s ease
    margin-bottom 20px
    margin-left auto
    margin-right auto
    box-shadow 0 4px 14px rgba(201, 162, 77, 0.35)
    
    // Responsive
    @media (max-width: 768px)
      width 90%
      max-width 400px
      height 42px
      padding 10px
      margin-bottom 12px
      border-radius 25px !important
      font-size 15px
      
    @media (max-width: 480px)
      width 95%
      max-width 350px
      height 38px
      font-size 14px
      padding 8px
      margin-bottom 10px
      border-radius 20px !important
      
    @media (max-width: 375px)
      width 95%
      max-width 320px
      height 35px
      font-size 13px
      padding 6px
      margin-bottom 8px
      border-radius 18px !important
    
    &:hover
      opacity 0.95
      transform translateY(-1px)
      
    &:disabled
      opacity 0.65
      cursor not-allowed
      transform none
      
  .login-link
    text-align center
    margin-top 8px
    
    // Responsive
    @media (max-width: 768px)
      margin-bottom 12px
      
    @media (max-width: 480px)
      margin-bottom 10px
      
    @media (max-width: 375px)
      margin-bottom 8px
    
    small
      color #666
      font-size 14px
      
      // Responsive
      @media (max-width: 768px)
        font-size 13px
        
      @media (max-width: 480px)
        font-size 12px
        
      @media (max-width: 375px)
        font-size 11px
      
      a
        color auth-gold
        text-decoration none
        
        &:hover
          text-decoration underline
          
  // Iconos sociales (Login/Register) - estilo tipo "burbujas" blancas con sombra
  .social-icons
    display flex
    justify-content center
    gap 14px
    margin-top 15px

  // En Login/Register los iconos vienen como <a class="fab fa-... social-icon facebook">
  // FontAwesome pinta el ícono en el ::before del <a>, por eso estilamos el propio <a>
  .social-icon
    width 68px
    height 68px
    border-radius 50%
    display inline-flex
    align-items center
    justify-content center
    text-decoration none
    background #fff
    box-shadow 0 10px 22px rgba(0,0,0,0.14)
    transition transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease
    font-size 30px
    line-height 1

    &:hover
      transform translateY(-2px)
      box-shadow 0 14px 28px rgba(0,0,0,0.18)

    // Colores por red (solo el ícono)
    &.facebook
      color #1877F2

    &.youtube
      color #FF0000

    &.tiktok
      color #111111

    &.whatsapp
      color #25D366

    &.instagram
      color #E4405F

    // Responsive
    @media (max-width: 768px)
      width 58px
      height 58px
      font-size 26px

    @media (max-width: 480px)
      width 52px
      height 52px
      font-size 24px

    @media (max-width: 375px)
      width 48px
      height 48px
      font-size 22px


  .social
    display flex
    justify-content center
