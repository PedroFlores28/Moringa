// Login – estilo Figma (panel crema, verde y dorado)

login-green = #13402c
login-gold = #c9a24d
login-gold-light = #e8d9a8
// Recorte del PNG Logoto.png (512×512): contenido visible y=55–455
logo-pad-top = 55 / 512
logo-pad-bottom = 56 / 512
logo-visible-ratio = 401 / 512
.login-panel
  width 100%
  max-width 460px
  margin 0 auto
  padding 8px 16px 24px
  font-family 'Open Sans', sans-serif

.login-form-header
  text-align center
  margin-bottom 28px

.login-form-logo-wrap
  width 122px
  height (122px * logo-visible-ratio)
  margin 0 auto
  overflow hidden

.login-form-logo
  width 122px
  height auto
  display block
  margin 0
  margin-top (-122px * logo-pad-top)

.login-form-brand
  margin 0
  font-size 13px
  font-weight 700
  letter-spacing 0.02em
  color login-gold
  line-height 1

.login-form-brand-sub
  margin 0 0 16px
  font-size 13px
  font-weight 700
  letter-spacing 0.02em
  color login-gold
  line-height 1
  margin-top -3px

.login-form-title
  margin 0
  font-size 22px
  font-weight 700
  color login-green
  line-height 1.2
  display flex
  flex-direction column
  align-items center
  gap 2px

.login-form-title-line
  display block
  text-align center

.login-field
  margin-bottom 6px
  text-align left

.login-label
  display block
  margin 0 0 8px 4px
  font-size 14px
  font-weight 700
  color login-green

.login-input-wrap
  position relative
  display block
  width 100%
  max-width 460px
  margin 0 auto

.login-field-icon
  position absolute
  top 50%
  transform translateY(-50%)
  color login-green
  font-size 18px
  line-height 1
  z-index 2
  pointer-events none

.login-field-icon--left
  left 18px

.login-field-icon--right
  right 16px
  pointer-events auto

.login-toggle-pass
  background transparent
  border none
  padding 4px
  cursor pointer
  display flex
  align-items center
  justify-content center

  &:focus
    outline none

.login-input
  width 100% !important
  max-width 100% !important
  height 52px !important
  margin 0 0 20px !important
  padding 0 48px !important
  box-sizing border-box !important
  display block !important
  border-radius 999px !important
  border 2px solid login-green !important
  background #f3f3f3 !important
  font-size 15px !important
  color #333 !important

  &::placeholder
    color #9a9a9a

  &.error
    border-color #c0392b !important

.login-input--password
  padding-right 52px !important

.login-button
  display block
  width 100%
  max-width 460px
  height 52px
  margin 8px auto 0
  padding 0 24px
  border none
  border-radius 999px
  background linear-gradient(90deg, #b8893a 0%, login-gold 45%, login-gold-light 100%)
  color #fff
  font-size 17px
  font-weight 700
  cursor pointer
  transition opacity 0.2s ease, transform 0.2s ease
  box-shadow 0 4px 14px rgba(201, 162, 77, 0.35)

  &:hover
    opacity 0.95
    transform translateY(-1px)

  &:disabled
    opacity 0.65
    cursor not-allowed
    transform none

.login-forgot
  margin 18px 0 0
  text-align center

  a
    color login-gold
    font-size 15px
    font-weight 500
    text-decoration none

    &:hover
      text-decoration underline

.alert
  color #c0392b
  font-size 14px
  text-align center
  margin 8px 0

.login-footer
  margin-top 20px

.login-link
  margin-top 12px !important

  small
    color #888

    a
      color login-gold
      text-decoration underline

.login-form-leaf
  display none

// Legacy (ocultar iconos viejos si quedan)
.dni-icon,
.show
  display none !important

@media (min-width: 1261px)
  .login-panel
    max-width 520px
    width 100%
    padding 16px 24px 32px

  .login-form-header
    margin-bottom 32px

  .login-form-logo-wrap
    width 214px
    height (214px * logo-visible-ratio)

  .login-form-logo
    width 214px
    margin-top (-214px * logo-pad-top)

  .login-form-brand
    font-size 14px
    letter-spacing 0.01em

  .login-form-brand-sub
    font-size 14px
    letter-spacing 0.01em
    margin-top -4px
    margin-bottom 18px

  .login-form-title
    font-size 26px
    gap 4px

  .login-form-title-line
    line-height 1.15

  .login-field
    width 100%
    max-width 380px
    margin-left auto
    margin-right auto

  .login-input-wrap,
  .login-button
    width 100%
    max-width 380px

  .login-input
    height 46px !important
    margin 0 0 16px !important
    font-size 14px !important
    border-radius 12px !important

  .login-button
    height 46px
    font-size 16px
    border-radius 12px

@media (max-width: 1260px)
  .login-button
    max-width 100%

  .login-input-wrap
    max-width 100%

@media (max-width: 768px)
  .login-form-header
    margin-bottom 16px

  .login-field
    width 100%
    max-width 268px
    margin-left auto
    margin-right auto

  .login-input-wrap,
  .login-button
    max-width 268px

  .login-input
    height 46px !important
    margin-bottom 16px !important
    border 2px solid login-green !important
    border-radius 12px !important
    background #f3f3f3 !important
    font-size 14px !important

  .login-button
    height 46px
    font-size 16px
    border-radius 12px
    background linear-gradient(90deg, #b8893a 0%, login-gold 45%, login-gold-light 100%)

@media (max-width: 480px)
  .login-panel
    padding 4px 12px 16px

  .login-field,
  .login-input-wrap,
  .login-button
    max-width 252px
