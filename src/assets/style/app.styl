*
  box-sizing border-box

@import 'vars.styl'

body, .app
  font-family global-font
  background app-bg
  color app-text
  margin 0
  padding 0
  overflow-x hidden

// Tarjetas y contenedores
.card, .profile-glass-card
  background app-bg-card
  color app-text
  border 1px solid app-border

.app
  min-height 100vh
  display flex 
  flex-direction column
  >header
    display flex
    align-items center
    justify-content space-between
    background c-menu-dark-bg
    color white
    padding 12px 16px
    gap 12px
    &.silver
      background linear-gradient(-225deg, #77FFD2 0%, #6297DB 48%, #1EECFF 100%)
    &.gold
      background linear-gradient(to right, #BF953F, #fff380, #B38728, #fff480, #AA771C)
    
    .header-left
      display flex
      align-items center
      flex-shrink 0
      
    .header-center
      position relative
      flex 1
      display flex
      align-items center
      justify-content center
      min-width 0
      
      .header-user-info
        position absolute
        display flex
        flex-direction column
        align-items flex-start
        gap 2px
        cursor move
        user-select none
        padding 4px 8px
        border-radius 4px
        transition background-color 0.2s
        
        &:hover
          background-color rgba(255, 255, 255, 0.1)
        
        &:active
          cursor grabbing
          background-color rgba(255, 255, 255, 0.15)
        
        .header-code
          font-size 14px
          font-weight 600
          white-space nowrap
          pointer-events none
          
        .header-dni
          font-size 13px
          opacity 0.9
          white-space nowrap
          pointer-events none
          
    .header-right
      display flex
      align-items center
      gap 12px
      flex-shrink 0
      
      .header-photo-label
        cursor pointer
        display flex
        align-items center
        
      .header-photo-container
        position relative
        width 40px
        height 40px
        border-radius 50%
        overflow hidden
        border 2px solid rgba(255, 255, 255, 0.3)
        transition all 0.3s ease
        
        &:hover .header-photo-overlay
          opacity 1
          
      .header-photo
        width 100%
        height 100%
        object-fit cover
        
      .header-photo-overlay
        position absolute
        top 0
        left 0
        width 100%
        height 100%
        background rgba(0, 0, 0, 0.4)
        display flex
        align-items center
        justify-content center
        color white
        font-size 14px
        opacity 0
        transition opacity 0.3s ease
        
      .header-photo-controls
        display flex
        gap 8px
        margin-left -4px
        
        i
          cursor pointer
          font-size 18px
          padding 4px
          border-radius 50%
          transition all 0.2s
          
          &.photo-control-confirm
            color #4CAF50
            &:hover
              background rgba(76, 175, 80, 0.1)
              
          &.photo-control-cancel
            color #f44336
            &:hover
              background rgba(244, 67, 54, 0.1)
        
      .header-icon
        font-size 18px
        cursor pointer
        padding 4px
        transition opacity 0.2s
        
        &:hover
          opacity 0.8
          
      .header-icon-link
        color white
        text-decoration none
        display flex
        align-items center
        
    .logo
      height 32px
      width auto
      
    .burger
      font-size 22px
      cursor pointer
      padding 4px
      
    @media (min-width: d-break)
      .header-center
        display none
      .header-right .header-icon.burger
        display none
  >section
    display flex
    flex 1
    // layout
    .menu
      padding 10px 20px
    .content
      transition all .5s
    .menu
      // En móvil el menú lateral no empuja el contenido, se muestra como overlay
      min-width 70%
      transform translate(-100%, 0)
    .content
      width 100%
      // Antes el contenido se desplazaba -70% para el efecto "push", lo que en móvil
      // hacía que solo se viera un pedazo de la vista y el resto fuera espacio en blanco.
      // Ahora el contenido ocupa siempre el 100% del ancho cuando el menú está oculto.
      // Eliminamos el transform para que position: fixed funcione correctamente en hijos.
      overflow auto
      position relative
      transition transform .5s
    /* En la vista de activación SOLO EN DESKTOP, quitar el transform translate para que el sticky funcione */
    @media (min-width: 1024px)
      body.activation-view &
        transform none !important
        transition none !important
    &.open
      .menu 
      .content
        // Cuando el menú está abierto en móviles, mantenemos el contenido fijo y
        // usamos el overlay móvil definido en App.vue, sin desplazar la vista.
        transform translate(0, 0)
        height auto
    // style
    .content
      background white 
      >header.page-topbar
        padding 18px 24px 14px
        display flex
        align-items center
        justify-content space-between
        gap 16px
        background #f5f7f4
        border-bottom none
        color c-menu-dark-bg

      .page-topbar__title
        margin 0
        font-size 22px
        font-weight 700
        color c-menu-dark-bg
        line-height 1.2

      .page-topbar__actions
        display flex
        align-items center
        gap 12px
        flex-shrink 0

      .page-topbar__notify
        position relative
        width 44px
        height 44px
        border none
        border-radius 12px
        background rgba(15, 42, 28, 0.07)
        display flex
        align-items center
        justify-content center
        cursor pointer
        flex-shrink 0
        transition background 0.2s

        &:hover
          background rgba(15, 42, 28, 0.12)

        i
          font-size 18px
          color c-menu-gold

      .page-topbar__notify-dot
        position absolute
        top 9px
        right 9px
        width 8px
        height 8px
        background #e53935
        border-radius 50%
        border 2px solid #f5f7f4

      .page-topbar__user
        display flex
        align-items center
        gap 12px
        padding 6px 14px 6px 6px
        background #fff
        border-radius 14px
        box-shadow 0 1px 6px rgba(15, 42, 28, 0.08)
        text-decoration none
        color inherit
        transition box-shadow 0.2s

        &:hover
          box-shadow 0 2px 10px rgba(15, 42, 28, 0.12)

      .page-topbar__avatar
        width 44px
        height 44px
        border-radius 50%
        overflow hidden
        flex-shrink 0
        margin 0
        cursor pointer
        position relative

        img
          width 100%
          height 100%
          object-fit cover
          display block

        input[type="file"]
          position absolute
          inset 0
          opacity 0
          cursor pointer

      .page-topbar__user-text
        min-width 0

      .page-topbar__name
        margin 0
        font-size 15px
        font-weight 700
        color #1a1a1a
        line-height 1.25
        white-space nowrap
        overflow hidden
        text-overflow ellipsis

      .page-topbar__email
        margin 2px 0 0
        font-size 12px
        color #6b7280
        line-height 1.2
        white-space nowrap
        overflow hidden
        text-overflow ellipsis

      .page-topbar__chevron
        font-size 11px
        color #4b5563
        flex-shrink 0
        margin-left 2px

      .page-topbar__photo-controls
        display flex
        gap 8px
        align-items center

      @media (max-width: m-break)
        .page-topbar__avatar
          display none

        .page-topbar__chevron
          display none

        .page-topbar__user
          display none

      >section
        padding 8px 16px
        padding-bottom 72px

      &.content--dashboard
        background #f5f7f4
        width 100%
        flex 1
        min-width 0

      >section.app-page--dashboard
        padding 14px 20px 72px
        width 100%
        max-width none
        box-sizing border-box
        background transparent

@media (max-width: 450px)
    .app >section .content >header
      display none

  .share-button
    background-color: c-moringa-forest-mid;
    color: #fff;
    border: none;
    border-radius: 5px;
    padding: 10px 20px;
    cursor: pointer;
    display: flex
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: bold;
    /* margin-left: 10px; */
    /* margin-left: 600px; */
    /* position: relative; */
    /* left: 400px; */
    /* transform: translate(500px, 0); */

    // Aumentar el margen izquierdo
.footer-register
  display flex
  color white

.footer-Dashboard
    position fixed
    bottom 0
    width 100%
    z-index 2100

    display: flex;
    justify-content: space-around;
    border-top: solid 1px app-border;
    background c-menu-dark-bg

    a
      display flex
      flex-direction column
      align-items center
      text-align center
      color white
      font-size 11px
      padding 6px 2px
      flex 1
      transition all 0.3s ease

      &.router-link-active, &.active
        color c-menu-active-pink
        i
          color c-menu-active-pink

    i
      display flex
      align-items center
      justify-content center
      font-size 22px
      height 22px
      width 22px
      margin-bottom 0px

    @media (min-width: d-break)
      display none


// Cuando hay un modal de producto abierto, resetear el transform del content
// Solo aplicar en móvil donde el transform afecta (menor a 768px)
@media (max-width: 767px)
  body.product-modal-open .app > section .content
    transform none !important
    transition none !important

@media (min-width: d-break)
  .app
    >header
      display none
    >section
      .menu
        min-width 300px // Balanced width
        width 300px
        transform translate(0, 0)
        position fixed
      .content
        flex 1
        margin-left 300px // Balanced offset
        min-width auto
        transform none
        >section
          padding 8px 32px

    body.book-reader-open &
      .content
        >header
          display none
        >section
          padding 0 !important


.menu
  position fixed
  top 0
  left 0
  height 100vh
  overflow hidden
  z-index 100
  background linear-gradient(180deg, #0f2a1c 0%, #0a1f14 55%, #081a12 100%)
  border-top-right-radius 16px
  border-bottom-right-radius 16px
  min-width 40%
  transform translate(-100%, 0)
  padding 0
  box-sizing border-box
  display flex
  flex-direction column
  box-shadow 4px 0 24px rgba(0, 0, 0, 0.25)

  &::before
    content ''
    position absolute
    left -20%
    bottom 0
    width 90%
    height 45%
    background radial-gradient(ellipse at bottom left, rgba(212, 175, 55, 0.08) 0%, transparent 70%)
    pointer-events none

  .text-header
    display none

  .sidebar-brand
    padding 24px 16px 18px
    border-bottom 1px solid c-menu-border
    text-align center

  .sidebar-logo-wrap
    width 158px
    height (158px * (401 / 512))
    margin 0 auto 10px
    overflow hidden

  .sidebar-logo-img
    width 158px
    height auto
    display block
    margin 0
    margin-top (-158px * (55 / 512))

  .sidebar-brand-title
    margin 0
    font-size 11px
    font-weight 700
    letter-spacing 0.01em
    color c-menu-gold
    line-height 1.25

  .sidebar-brand-sub
    margin 6px 0 0
    font-size 10px
    font-weight 600
    letter-spacing 0.03em
    color c-menu-gold-soft
    line-height 1

  .sidebar-profile-card
    margin 12px 12px 16px
    padding 18px 14px 14px
    border 1px solid c-menu-gold
    border-radius 16px
    background rgba(0, 0, 0, 0.22)
    flex-shrink 0
    display flex
    flex-direction column
    align-items center
    text-align center

  .sidebar-profile-main
    display flex
    flex-direction column
    align-items center
    width 100%
    margin-bottom 0

  .sidebar-profile-text
    width 100%

  .sidebar-profile-avatar
    width 56px
    height 56px
    border-radius 50%
    overflow hidden
    border 2px solid c-menu-gold
    flex-shrink 0
    margin 0 0 10px
    background rgba(212, 175, 55, 0.15)
    img
      width 100%
      height 100%
      object-fit cover

  .sidebar-profile-name
    margin 0
    font-size 15px
    font-weight 700
    color #fff
    line-height 1.2
    width 100%

  .sidebar-profile-email
    margin 6px 0 0
    font-size 12px
    color c-menu-text-muted
    line-height 1.25
    width 100%
    word-break break-word

  .sidebar-profile-actions
    display grid
    grid-template-columns repeat(3, 1fr)
    align-items center
    justify-items center
    width 100%
    margin-top 14px
    padding-top 12px
    border-top 1px solid c-menu-border

  .sidebar-profile-action
    display inline-flex
    align-items center
    justify-content center
    width 44px
    height 44px
    padding 0
    margin 0
    box-sizing border-box
    background transparent
    border none
    border-radius 8px
    color c-menu-gold
    font-size 20px
    line-height 1
    cursor pointer
    text-decoration none
    transition background 0.2s ease, opacity 0.2s ease
    flex-shrink 0

    i
      margin 0
      width auto
      font-size 20px
      color inherit

    &:hover
      opacity 1
      background rgba(212, 175, 55, 0.14)
      color c-menu-gold-soft

    &.router-link-active
      background rgba(212, 175, 55, 0.14)
      color c-menu-gold

  .menu-scroll-container
    flex 1
    overflow-y auto
    display flex
    flex-direction column
    -ms-overflow-style none // IE/Edge legacy
    scrollbar-width none // Firefox

    &::-webkit-scrollbar
      width 0
      height 0

  .text-header
    border-bottom 1px solid c-menu-border
    margin-bottom 20px
    padding 20px

  .photo-logo
    display none

  a:not(.sidebar-profile-action)
    position relative
    background transparent
    display flex
    align-items center
    color c-menu-text-dim
    font-size 15px
    padding 18px 24px
    border-bottom 1px solid rgba(255, 255, 255, 0.06)
    margin-bottom 0
    border-radius 0
    transition all 0.2s ease
    cursor pointer

    span
      display flex
      align-items center

    &:first-of-type
      border-top none

    img, i, svg
      width 20px
      text-align center
      margin-right 12px
      opacity 0.95
      color c-menu-gold

    &:hover,
    &.router-link-active,
    &.active-parent,
    &.active
      background c-menu-active-bg
      color #fff
      border-radius 10px
      margin 2px 10px
      padding-left 14px
      padding-right 14px
      border-bottom-color transparent
      img, i, svg
        opacity 1
        color c-menu-gold
        path
          fill currentColor

    &.active-parent i.fa-angle-down,
    &:hover i.fa-angle-down
      color #fff

    &.active-parent i.fa-angle-down
      transform rotate(180deg)

    i.fa-angle-down
      transition transform 0.3s ease
      font-size 16px
      margin-left auto
      margin-right 0

  .logout-button
    display none

@media (min-width: d-break)
  .menu
    a:not(.sidebar-profile-action)
      padding-right 24px


.sub-menu
  display none
  background rgba(0, 0, 0, 0.15)
  border-bottom 1px solid rgba(255, 255, 255, 0.06)
  margin-bottom 0
  
  a
    font-size 13px
    padding 16px 24px 16px 48px
    margin-bottom 2px
    border-left none
    background transparent
    color c-menu-text-dim
    
    &::before
      display none // Only main categories should have the left vertical bar

    i
      font-size 16px !important
      width 20px
      text-align center
      
    svg
      width 18px !important
      height auto


    &:hover,
    &.router-link-active
      background c-menu-active-bg
      color c-menu-text-dim
      border-left none
      border-radius 8px
      margin 4px 12px
      padding-left 33px
      font-weight inherit
      
      i, svg, img
        color c-menu-gold
        opacity 0.95
        
        path
          fill currentColor
          
      i
        font-size 16px


  
  &.active
    display block
    border-radius 8px


