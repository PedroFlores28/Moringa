@import '../vars.styl'

$moringa-spinner-track = #e8f0eb
$moringa-spinner-color = c-moringa-forest-mid

@keyframes moringa-spin
  to
    transform rotate(360deg)

// Spinner circular (vistas, overlays, inicialización)
.loading-spinner,
.loading-spinner-large,
.loading-spinner-medium
  border-radius 50%
  animation moringa-spin 1s linear infinite
  box-sizing border-box

.loading-spinner
  width 40px
  height 40px
  border 3px solid $moringa-spinner-track
  border-top-color $moringa-spinner-color

.loading-spinner-medium
  width 48px
  height 48px
  border 4px solid $moringa-spinner-track
  border-top-color $moringa-spinner-color

.loading-spinner-large
  width 60px
  height 60px
  border 4px solid $moringa-spinner-track
  border-top-color $moringa-spinner-color
  margin-bottom 20px

.loading-container
  display flex
  flex-direction column
  align-items center
  justify-content center
  text-align center

  .fa-spinner
    color $moringa-spinner-color

  p
    color #666
    font-size 1rem
    margin 0

// Font Awesome en botones / formularios mientras cargan
section .fa-spinner.fa-spin,
.loading-overlay .fa-spinner.fa-spin,
.order-btn.loading .fa-spinner
  color $moringa-spinner-color

// Spinner pequeño inline (árbol, bonos, etc.)
.load
  display block
  height 18px
  width 18px
  border-radius 50%
  border 2px solid rgba(c-moringa-forest-mid, 0.2)
  border-top-color c-moringa-forest-mid
  border-right-color transparent
  border-bottom-color transparent
  animation 0.9s linear infinite moringa-spin
  margin auto
